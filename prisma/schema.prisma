generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
  permissions RolePermission[]
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  locations Location[]
  users     User[]
  tickets   Ticket[]
  actionItems ActionItem[]
  permittedMeetings    Meeting[]    @relation("MeetingPermittedDepartments")
  permittedTickets     Ticket[]     @relation("TicketPermittedDepartments")
}

model Location {
  id           Int        @id @default(autoincrement())
  city         String
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  users        User[]
}

model User {
  id           Int         @id @default(autoincrement())
  email        String      @unique
  name         String?
  avatarUrl    String?
  signature    String?
  password     String      @default("password123")
  roleId       Int
  role         Role        @relation(fields: [roleId], references: [id])
  departmentId Int
  department   Department  @relation(fields: [departmentId], references: [id])
  locationId   Int?
  location     Location?   @relation(fields: [locationId], references: [id])
  tickets      Ticket[]    @relation("AssignedUser")
  reports      DailyReport[]
  comments     Comment[]
  historyLogs  TicketHistory[]
  attachments  Attachment[]
  meetingsOrganized Meeting[] @relation("MeetingOrganizer")
  meetingsAttending Meeting[] @relation("MeetingAttendees")
  presentSessions   MeetingSession[] @relation("SessionPresentAttendees")
  meetingSessions   MeetingSession[]
  actionItems       ActionItem[]
  schedulePreference UserSchedulePreference?
  schedules         ShiftSchedule[]
  articles          KnowledgeArticle[]
  userPermissions   UserPermission[]
  visitPermitsApproved VisitPermit[] @relation("PermitApprover")
}

model Ticket {
  id           Int        @id @default(autoincrement())
  trackingId   String?    @unique @default(uuid())
  title        String
  description  String
  status       String     @default("New")
  customData   Json?
  priority     String     @default("Medium")
  
  // SLA Tracking (Phase 22)
  nextSlaDeadline DateTime?
  slaBreaches     Int       @default(0)
  slaTimerMins    Int       @default(15)
  enableSla       Boolean   @default(false)
  
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  assigneeId   Int?
  assignee     User?      @relation("AssignedUser", fields: [assigneeId], references: [id])
  jobCategoryId Int?
  jobCategory  JobCategory? @relation(fields: [jobCategoryId], references: [id])
  awardedScore Int?
  comments     Comment[]
  historyLogs  TicketHistory[]
  attachments  Attachment[]
  meetings     Meeting[]
  actionItem   ActionItem?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  resolvedAt   DateTime?
  services     Service[]
  visibility           String       @default("Public") 
  permittedDepartments Department[] @relation("TicketPermittedDepartments")
  rfs                  DateTime?
  deletedAt            DateTime?
}

model DailyReport {
  id        Int      @id @default(autoincrement())
  content   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Meeting {
  id            Int      @id @default(autoincrement())
  title         String
  agenda        String?
  problems      String?
  solutions     String?
  status        String   @default("Scheduled") 
  scheduledAt   DateTime
  organizedById Int?
  organizedBy   User?    @relation("MeetingOrganizer", fields: [organizedById], references: [id])
  attendees     User[]   @relation("MeetingAttendees")
  sessions      MeetingSession[]
  actionItems   ActionItem[]
  discussedTickets Ticket[]
  createdAt     DateTime @default(now())
  visibility           String       @default("Public")
  permittedDepartments Department[] @relation("MeetingPermittedDepartments")
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  attachments Attachment[]
  createdAt DateTime @default(now())
  deletedAt DateTime?
}

model CustomField {
  id       Int     @id @default(autoincrement())
  name     String
  type     String  @default("text") 
  options  String? 
  required Boolean @default(false)
  active   Boolean @default(true)
  position String  @default("bottom")
}

model TicketHistory {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  action    String   
  actorId   Int?     
  actor     User?    @relation(fields: [actorId], references: [id])
  
  // Segmented Timeline Point Ledger
  jobCategoryId Int?
  awardedScore  Int?
  
  createdAt DateTime @default(now())
}

model Attachment {
  id         Int      @id @default(autoincrement())
  filename   String
  url        String
  ticketId   Int?
  ticket     Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  commentId  Int?
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploadedBy Int
  uploader   User     @relation(fields: [uploadedBy], references: [id])
  createdAt  DateTime @default(now())
}

model JobCategory {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  score    Int      @default(0)
  active   Boolean  @default(true)
  tickets  Ticket[]
}

model ActionItem {
  id           Int      @id @default(autoincrement())
  task         String
  status       String   @default("Pending") 
  meetingId    Int
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingSessionId Int?
  meetingSession   MeetingSession? @relation(fields: [meetingSessionId], references: [id], onDelete: Cascade)
  assigneeId   Int?
  assignee     User?    @relation(fields: [assigneeId], references: [id])
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  linkedTicketId Int?      @unique
  linkedTicket   Ticket?   @relation(fields: [linkedTicketId], references: [id])
  dueDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MeetingSession {
  id        Int      @id @default(autoincrement())
  meetingId Int
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  title     String?
  scheduledFor DateTime?
  content   String?  @db.Text
  authorId  Int      
  author    User     @relation(fields: [authorId], references: [id])
  presentAttendees User[] @relation("SessionPresentAttendees")
  actionItems ActionItem[]
  createdAt DateTime @default(now())
}

model ShiftType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  startTime String 
  endTime   String 
  preferences UserSchedulePreference[]
  schedules   ShiftSchedule[]
  active    Boolean  @default(true)
}

model UserSchedulePreference {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleMode   String    @default("RANDOM") 
  fixedShiftId   Int?
  fixedShift     ShiftType? @relation(fields: [fixedShiftId], references: [id])
  fixedOffDays   String    @default("[]") 
}

model ShiftSchedule {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  shiftTypeId Int?     
  shiftType   ShiftType? @relation(fields: [shiftTypeId], references: [id])
  
  @@unique([userId, date])
}

// ==========================================
// Phase 32: Knowledge Base
// ==========================================

model KnowledgeCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  icon        String?
  articles    KnowledgeArticle[]
}

model KnowledgeArticle {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  categoryId  Int
  category    KnowledgeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// Phase 33: Telecom Asset Management
// ==========================================

model Customer {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  contactEmail String?
  contactPhone String?
  services     Service[]
  rackEquipments RackEquipment[]
  crossConnects CrossConnect[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ServiceTemplate {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  fields      Json      @default("[]") // Defines dynamic schema fields
  active      Boolean   @default(true)
  services    Service[]
}

model Service {
  id           Int        @id @default(autoincrement())
  customerId   Int
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  templateId   Int
  template     ServiceTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  name         String
  status       String     @default("Active")
  customData   Json?      // Stores actual field values mapped to Template
  monthlyCost  Decimal?
  currency     String     @default("IDR")
  contractEnd  DateTime?
  hops         CircuitHop[]
  tickets      Ticket[]   // M:N Relation with Tickets
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model CircuitHop {
  id          Int      @id @default(autoincrement())
  serviceId   Int
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orderIndex  Int      @default(0)
  location    String
  deviceName  String
  portName    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// RBAC Permission System
// ==========================================

model Permission {
  id    Int    @id @default(autoincrement())
  key   String @unique
  label String
  group String @default("other")
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  roleId       Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

model UserPermission {
  userId       Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  granted      Boolean    @default(true)
  @@id([userId, permissionId])
}

// ==========================================
// Phase 34: Datacenter & Visitor Management System (VMS)
// ==========================================

model DCSite {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  nocEmail    String?  
  racks       Rack[]
  permits     VisitPermit[]
  crossConnects CrossConnect[]
  createdAt   DateTime @default(now())
}

model Rack {
  id          Int      @id @default(autoincrement())
  siteId      Int
  site        DCSite   @relation(fields: [siteId], references: [id])
  name        String   
  uCapacity   Int      @default(42)
  equipments  RackEquipment[]
  aSideCables CrossConnect[] @relation("CrossConnectSideA")
  zSideCables CrossConnect[] @relation("CrossConnectSideZ")
  affectedBy  VendorMaintenance[] @relation("MaintenanceAffectedRacks")
  createdAt   DateTime @default(now())
}

model RackEquipment {
  id          Int      @id @default(autoincrement())
  rackId      Int
  rack        Rack     @relation(fields: [rackId], references: [id], onDelete: Cascade)
  customerId  Int?
  customer    Customer? @relation(fields: [customerId], references: [id])
  name        String
  uStart      Int
  uEnd        Int
  status      String   @default("Active")
  createdAt   DateTime @default(now())
}

model VisitPermit {
  id          Int      @id @default(autoincrement())
  siteId      Int
  site        DCSite   @relation(fields: [siteId], references: [id])
  companyName String
  visitorNames String
  activity    String
  scheduledAt DateTime
  checkInAt   DateTime?
  checkOutAt  DateTime?
  status      String   @default("Pending") 
  approvedById Int?
  approvedBy  User?    @relation("PermitApprover", fields: [approvedById], references: [id])
  createdAt   DateTime @default(now())
}

model CrossConnect {
  id              Int      @id @default(autoincrement())
  siteId          Int
  site            DCSite   @relation(fields: [siteId], references: [id])
  customerId      Int?
  customer        Customer? @relation(fields: [customerId], references: [id])
  mediaType       String   @default("Singlemode Fiber") 
  sideARackId     Int
  sideARack       Rack     @relation("CrossConnectSideA", fields: [sideARackId], references: [id])
  sideAPort       String
  sideZRackId     Int
  sideZRack       Rack     @relation("CrossConnectSideZ", fields: [sideZRackId], references: [id])
  sideZPort       String
  status          String   @default("Requested") 
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model VendorMaintenance {
  id              Int      @id @default(autoincrement())
  type            String   
  startTime       DateTime
  endTime         DateTime?
  slaDowntimeMins Int      @default(0)
  affectedRacks   Rack[]   @relation("MaintenanceAffectedRacks")
  description     String?
  createdAt       DateTime @default(now())
}
